### Prueba
POST http://localhost:8000/api/v1/ai/ask
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjoxLCJlbWFpbCI6InVzZXJAZXhhbXBsZS5jb20iLCJleHAiOjE3Nzk1MTcyMDB9.zPD3iwmQzVfExl0m_tl-UoEzJQ10woZINwdaBSOb_dE

{
    "chat_id" : "session_default",
    "question": "Que pasos hago para casarme",
    "document": null,
    "provider" : "llama",
    "image": null
}

